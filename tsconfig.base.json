{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@eightyfourthousand/client-graphql": [
        "libs/client-graphql/src/index.ts"
      ],
      "@eightyfourthousand/client-graphql/ssr": [
        "libs/client-graphql/src/ssr.ts"
      ],
      "@eightyfourthousand/data-access": [
        "libs/data-access/src/index.ts"
      ],
      "@eightyfourthousand/data-access/ssr": [
        "libs/data-access/src/ssr.ts"
      ],
      "@eightyfourthousand/design-system": [
        "libs/design-system/src/index.ts"
      ],
      "@eightyfourthousand/design-system/ssr": [
        "libs/design-system/src/ssr.ts"
      ],
      "@eightyfourthousand/design-system/css": [
        "libs/design-system/src/lib/theme/global.css"
      ],
      "@eightyfourthousand/lib-editing": [
        "libs/lib-editing/src/index.ts"
      ],
      "@eightyfourthousand/lib-editing/ssr": [
        "libs/lib-editing/src/ssr.ts"
      ],
      "@eightyfourthousand/lib-editing/fixtures/*": [
        "libs/lib-editing/src/fixtures/*"
      ],
      "@eightyfourthousand/lib-instr": [
        "libs/lib-instr/src/index.ts"
      ],
      "@eightyfourthousand/lib-instr/ssr": [
        "libs/lib-instr/src/ssr.ts"
      ],
      "@eightyfourthousand/lib-instr/static": [
        "libs/lib-instr/src/static.ts"
      ],
      "@eightyfourthousand/lib-search": [
        "libs/lib-search/src/index.ts"
      ],
      "@eightyfourthousand/lib-utils": [
        "libs/lib-utils/src/index.ts"
      ],
      "@lib-explore": [
        "libs/lib-explore/src/index.ts"
      ],
      "@lib-explore/ssr": [
        "libs/lib-explore/src/ssr.ts"
      ],
      "@lib-search": [
        "libs/lib-search/src/index.ts"
      ],
      "@lib-user": [
        "libs/lib-user/src/index.ts"
      ],
      "@lib-user/ssr": [
        "libs/lib-user/src/ssr.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
